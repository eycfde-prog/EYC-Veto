(function(){'use strict';
var _e="";
function _d(s){try{return JSON.parse(atob(s));}catch(e){return [];}}
var TIT=["حين يبتلع الجبل أسراره","عيون لا ترى ولا تكذب","الجنة التي أكلها الظلام","ما وراء الكهف والحقيقة","محاكمة بين ثلج ودم"];
var NUM=["الفصل الأول","الفصل الثاني","الفصل الثالث","الفصل الرابع","الفصل الخامس"];
var cur=0,fs=19,ti=0,TH=['','night','sepia'],IC=['\u{1F319}','\u2600\uFE0F','\u{1F4DC}'],DATA=null;
function getData(){if(!DATA)DATA=_d(_e);return DATA;}

function createSnow(){
  var c=document.getElementById('snowContainer');if(!c)return;
  for(var i=0;i<50;i++){var f=document.createElement('div');f.className='snowflake';f.textContent='\u00B7';
    f.style.left=(Math.random()*100)+'vw';f.style.animationDuration=(Math.random()*8+5)+'s';
    f.style.animationDelay=(Math.random()*10)+'s';f.style.fontSize=(Math.random()*8+4)+'px';
    c.appendChild(f);}
}

function buildPills(){
  var c=document.getElementById('landingChapters');if(!c)return;
  TIT.forEach(function(t,i){var b=document.createElement('button');b.className='ch-pill';
    b.textContent=NUM[i].replace('\u0627\u0644\u0641\u0635\u0644 ','\u0641')+' \u00B7 '+t;
    b.onclick=function(){openReader(i);};c.appendChild(b);});
}

function buildNav(){
  var n=document.getElementById('chapterNav');if(!n)return;n.innerHTML='';
  TIT.forEach(function(t,i){var b=document.createElement('button');
    b.className='ch-nav-btn'+(i===cur?' active':'');
    b.textContent=NUM[i].replace('\u0627\u0644\u0641\u0635\u0644 ','\u0641')+': '+t;
    b.onclick=function(){loadChapter(i);};n.appendChild(b);});
}

function fixLayout(){
  var h=document.getElementById('readerHeader'),n=document.getElementById('chapterNav'),a=document.getElementById('readingArea');
  if(!h||!n||!a)return;
  var hh=h.offsetHeight;n.style.top=hh+'px';
  setTimeout(function(){a.style.paddingTop=(hh+n.offsetHeight+12)+'px';},60);
}

window.openReader=function(idx){
  document.getElementById('landing').style.display='none';
  document.getElementById('reader').style.display='block';
  buildNav();loadChapter(idx);window.scrollTo(0,0);
  window.addEventListener('scroll',updateProgress);
  setTimeout(fixLayout,80);
};
window.addEventListener('resize',fixLayout);

window.goBack=function(){
  document.getElementById('reader').style.display='none';
  document.getElementById('landing').style.display='flex';
  window.scrollTo(0,0);
};

window.loadChapter=function(idx){
  cur=idx;var d=getData(),p=d[idx]||[];
  document.getElementById('headerTitle').textContent=TIT[idx];
  document.querySelectorAll('.ch-nav-btn').forEach(function(b,i){b.classList.toggle('active',i===idx);});
  var mins=Math.ceil(p.join(' ').split(' ').length/200);
  var h='<div class="chapter-header"><div class="chapter-num">'+NUM[idx]+'</div>'
    +'<h2 class="chapter-title">'+TIT[idx]+'</h2>'
    +'<div class="chapter-ornament"><div class="chapter-ornament-diamond"></div></div>'
    +'<div class="reading-time">\u0648\u0642\u062A \u0627\u0644\u0642\u0631\u0627\u0621\u0629 \u0627\u0644\u062A\u0642\u062F\u064A\u0631\u064A: ~'+mins+' \u062F\u0642\u064A\u0642\u0629</div>'
    +'</div><div class="story-text chapter-content">';
  p.forEach(function(t){h+='<p>'+t+'</p>';});
  h+='</div><div class="reader-footer">';
  if(idx>0)h+='<button class="nav-btn-end" onclick="loadChapter('+(idx-1)+');window.scrollTo(0,0)">'
    +'\u2190 \u0627\u0644\u0641\u0635\u0644 \u0627\u0644\u0633\u0627\u0628\u0642</button>';
  if(idx<4)h+='<button class="nav-btn-end" onclick="loadChapter('+(idx+1)+');window.scrollTo(0,0)">'
    +'\u0627\u0644\u0641\u0635\u0644 \u0627\u0644\u062A\u0627\u0644\u064A \u2192</button>';
  else h+='<p style="font-family:Amiri,serif;font-size:1.3rem;margin-top:1rem">\u062A\u0645\u062A \u0627\u0644\u0631\u0648\u0627\u064A\u0629 \u2756</p>';
  h+='</div>';
  document.getElementById('chapterContent').innerHTML=h;
  applyFs();window.scrollTo(0,0);updateProgress();
};

function applyFs(){
  document.querySelectorAll('.story-text p').forEach(function(p){p.style.fontSize=fs+'px';});
  var d=document.getElementById('fontSizeDisplay');if(d)d.textContent=fs;
}
window.changeFontSize=function(delta){fs=Math.min(28,Math.max(14,fs+delta));applyFs();};

window.cycleTheme=function(){
  var c=TH[ti];if(c)document.body.classList.remove(c);
  ti=(ti+1)%TH.length;var n=TH[ti];if(n)document.body.classList.add(n);
  var b=document.getElementById('themeBtn');if(b)b.textContent=IC[ti];
};

function updateProgress(){
  var st=window.scrollY,dh=document.documentElement.scrollHeight-window.innerHeight;
  var f=document.getElementById('progressFill');
  if(f)f.style.width=(dh>0?(st/dh)*100:0)+'%';
}
window.updateProgress=updateProgress;

function protect(){
  document.addEventListener('selectstart',function(e){e.preventDefault();});
  document.addEventListener('contextmenu',function(e){e.preventDefault();});
  document.addEventListener('keydown',function(e){
    if((e.ctrlKey||e.metaKey)&&['c','x','u','s','p','a'].indexOf(e.key.toLowerCase())>-1)e.preventDefault();
  });
  document.addEventListener('dragstart',function(e){e.preventDefault();});
}

document.addEventListener('DOMContentLoaded',function(){protect();createSnow();buildPills();});
})();
