        clearInterval(timerInterval);
        timeLeft = 120;
        isRunning = false;
        startBtn.innerText = "Start";
        startBtn.disabled = false;
        startBtn.style.background = "#0ea5e9";
        startBtn.style.boxShadow = "0 6px 0 #0369a1";
        updateDisplay();
    };

})();

